{
    // Example launch configuration for CoreDemo (C#)
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Debug (CLI)",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": [
                "exec",
                "${workspaceFolder}/CoreDemo/bin/Debug/net10.0/CoreDemo.dll"
            ],
            "cwd": "${workspaceFolder}/CoreDemo"
        },
                
        {
            "name": ".NET Core Launch (web , net10.0 CLI)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/CoreDemo/bin/Debug/net10.0/CoreDemo.dll",
            "args": [
                "exec", 
                "${workspaceFolder}/CoreDemo/bin/Debug/net10.0/CoreDemo.dll"
            ],
            "cwd": "${workspaceFolder}/CoreDemo",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Now listening on: (https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
    ]
}
